# Copie este arquivo para .env e preencha os valores antes de subir o container

# App
DEBUG=false

# Banco PostGIS (compartilhado com o Core Service)
DATABASE_URL=postgresql+asyncpg://geolvix_user:TROQUE_AQUI@postgres:5432/geolvix

# Token interno — deve ser igual ao configurado no Core Service
# Gere com: python -c "import secrets; print(secrets.token_hex(32))"
INTERNAL_API_TOKEN=TROQUE_POR_TOKEN_SEGURO

# Simplificação de geometria (Douglas-Peucker, em graus decimais)
# 0.00001 ≈ 1 metro na linha do Equador
GEOMETRY_SIMPLIFY_TOLERANCE=0.00001

# CORS
ALLOWED_ORIGINS=["http://localhost:3000","http://core-service:8080"]

# Sentry (opcional — deixe em branco para desabilitar)
SENTRY_DSN=
